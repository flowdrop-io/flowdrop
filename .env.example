# FlowDrop Development Configuration
# Copy this file to .env for local development

# API Base URL for development
VITE_API_BASE_URL=http://localhost:8000/api/flowdrop

# Alternative API URLs (used as fallbacks)
# VITE_DRUPAL_API_URL=http://localhost:8080/api/flowdrop
# VITE_FLOWDROP_API_URL=/api/flowdrop

# API Configuration
# VITE_FLOWDROP_TIMEOUT=30000
# VITE_FLOWDROP_AUTH_TYPE=bearer
# VITE_FLOWDROP_AUTH_TOKEN=your-token-here

# Theme
# VITE_FLOWDROP_THEME=auto

# Note: These environment variables are ONLY for development/demo purposes
# The library itself does not use environment variables and relies on runtime configuration
