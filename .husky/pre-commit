#!/usr/bin/env sh

# Check if any API files are staged
API_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep "^libs/flowdrop/api/" | grep -v "bundled.yaml" || true)

if [ -n "$API_FILES" ]; then
  echo "📦 API files changed, bundling OpenAPI specs..."
  cd apps/api-docs && pnpm run bundle && cd ../..

  # Check if any bundled.yaml was modified
  BUNDLED_CHANGES=$(git diff libs/flowdrop/api/*/bundled.yaml 2>/dev/null || true)
  if [ -n "$BUNDLED_CHANGES" ]; then
    echo "✅ Bundled specs updated, staging changes..."
    git add libs/flowdrop/api/*/bundled.yaml
  else
    echo "✅ Bundled specs already up to date"
  fi
fi

# Optional: Run linting on staged API files
if [ -n "$API_FILES" ]; then
  echo "🔍 Linting API specs..."
  cd apps/api-docs && pnpm run lint && cd ../..
fi
