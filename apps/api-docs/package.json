{
	"name": "@d34dman/flowdrop-api-docs",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"lint": "redocly lint ../../libs/flowdrop/api/openapi.yaml --config ../../libs/flowdrop/api/redocly.yaml",
		"bundle": "redocly bundle ../../libs/flowdrop/api/openapi.yaml -o ../../libs/flowdrop/api/bundled.yaml --config ../../libs/flowdrop/api/redocly.yaml",
		"preview": "node scripts/preview.mjs",
		"build": "redocly build-docs ../../libs/flowdrop/api/bundled.yaml -o dist/index.html"
	},
	"devDependencies": {
		"@redocly/cli": "^1.31.0"
	}
}
