---
/**
 * Standalone node preview page.
 * Renders a single FlowDrop node on a SvelteFlow canvas.
 * Loaded in an iframe from the docs site for style isolation.
 * Query params (parsed client-side):
 *   ?type=default  — node type to preview (default|simple|square|tool|gateway|terminal|idea|note)
 *   ?theme=dark    — color theme (dark|light)
 */
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<title>Node Preview</title>
		<style is:global>
			*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
			html, body { width: 100%; height: 100%; overflow: hidden; }
			body { font-family: system-ui, sans-serif; }
			body.dark { background: #1a1a2e; color: #e0e0e0; }
			body.light { background: #f8f9fa; color: #1a1a2e; }
			#preview { width: 100%; height: 100%; }
			#loading {
				display: flex;
				align-items: center;
				justify-content: center;
				height: 100%;
				color: #9ca3af;
				font-size: 0.875rem;
			}
			.hidden { display: none !important; }
		</style>
	</head>
	<body class="dark">
		<div id="loading">Loading...</div>
		<div id="preview" class="hidden"></div>

		<script>
			(async () => {
				const params = new URLSearchParams(window.location.search);
				const nodeType = params.get('type') || 'default';
				const theme = params.get('theme') || 'dark';

				document.body.classList.remove('dark', 'light');
				document.body.classList.add(theme);

				const loadingEl = document.getElementById('loading');
				const previewEl = document.getElementById('preview');

				try {
					const { mount } = await import('svelte');
					const { default: NodePreview } = await import('../components/NodePreview.svelte');
					const { nodePreviewData } = await import('../mocks/node-preview-data');

					const data = nodePreviewData[nodeType] || nodePreviewData['default'];

					loadingEl.classList.add('hidden');
					previewEl.classList.remove('hidden');

					mount(NodePreview, {
						target: previewEl,
						props: { data, theme }
					});
				} catch (err) {
					console.error('Node preview failed:', err);
					loadingEl.textContent = 'Failed to load preview';
				}

				// Listen for theme changes from parent
				window.addEventListener('message', (event) => {
					if (event.data?.type === 'theme-change') {
						// Reload with new theme
						const url = new URL(window.location.href);
						url.searchParams.set('theme', event.data.theme);
						window.location.href = url.toString();
					}
				});
			})();
		</script>
	</body>
</html>
