---
/**
 * Standalone FlowDrop demo page.
 * Rendered in an iframe from the docs site for complete style isolation.
 * Query params (parsed client-side):
 *   ?readOnly=true   — read-only mode (no editing)
 *   ?step=1           — tutorial step (1-4)
 */
---

<!doctype html>
<html lang="en" data-theme="dark">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<title>FlowDrop Demo</title>
		<style>
			*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
			html, body { width: 100%; height: 100%; overflow: hidden; }
			body { background: #0a0a0f; color: #c0c0d8; font-family: system-ui, sans-serif; }
			#editor { width: 100%; height: 100%; }
			#loading {
				display: flex;
				flex-direction: column;
				align-items: center;
				justify-content: center;
				height: 100%;
				gap: 1rem;
				color: #7a7a9a;
			}
			.spinner {
				width: 2rem;
				height: 2rem;
				border: 3px solid #2a2a3a;
				border-top-color: #6c63ff;
				border-radius: 50%;
				animation: spin 0.8s linear infinite;
			}
			@keyframes spin { to { transform: rotate(360deg); } }
			.error {
				display: flex;
				flex-direction: column;
				align-items: center;
				justify-content: center;
				height: 100%;
				gap: 0.5rem;
				color: #7a7a9a;
				text-align: center;
				padding: 2rem;
			}
			.error strong { color: #c0c0d8; }
			.hidden { display: none !important; }

			/* Minimal (slate) skin tokens — applied in dark mode */
			:root {
				--fd-node-icon-display: none;
				--fd-node-circle-display: flex;
				--fd-sidebar-search-display: none;
				--fd-sidebar-header-display: none;
				--fd-sidebar-card-display: none;
				--fd-sidebar-flat-display: block;
				--fd-navbar-split-display: flex;
				--fd-navbar-dropdown-display: none;
			}
			[data-theme='dark'] {
				--fd-background: #13131a;
				--fd-foreground: #c0c0d8;
				--fd-muted: #1a1a28;
				--fd-muted-foreground: #7a7a9a;
				--fd-card: #1a1a28;
				--fd-card-foreground: #e8e8f0;
				--fd-border: #2a2a3a;
				--fd-border-muted: #1e1e2a;
				--fd-border-strong: #3a3a55;
				--fd-header: #1a1a25;
				--fd-layout-background: #0a0a0f;
				--fd-primary: #6c63ff;
				--fd-primary-hover: #7c74ff;
				--fd-primary-foreground: #ffffff;
				--fd-primary-muted: rgba(108, 99, 255, 0.15);
				--fd-scrollbar-thumb: #2a2a3a;
				--fd-scrollbar-track: #13131a;
				--fd-backdrop: rgba(19, 19, 26, 0.9);
				--fd-node-border: #9898b8;
				--fd-node-border-hover: #aeaed0;
				--fd-handle-border: #9898b8;
				--fd-sidebar-category-color: #3a3a55;
				--fd-sidebar-flat-item-color: #8888aa;
			}
		</style>
	</head>
	<body>
		<div id="loading">
			<div class="spinner"></div>
			<p>Loading editor...</p>
		</div>
		<div id="error" class="error hidden">
			<p><strong>Could not load the demo.</strong></p>
			<p>Check the browser console for details.</p>
		</div>
		<div id="editor" class="hidden"></div>

		<script>
			(async () => {
				const params = new URLSearchParams(window.location.search);
				const config = {
					readOnly: params.get('readOnly') === 'true',
					step: params.get('step') || '',
					zoom: params.get('zoom') ? parseFloat(params.get('zoom')) : null
				};
				const loadingEl = document.getElementById('loading');
				const errorEl = document.getElementById('error');
				const editorEl = document.getElementById('editor');

				try {
					// Determine handlers and mount options based on tutorial step
					let handlers;
					let mountOptions;

					const { setupWorker } = await import('msw/browser');
					const { mountFlowDropApp } = await import('@flowdrop/flowdrop/editor');
					const { createEndpointConfig } = await import('@flowdrop/flowdrop/core');
					await import('@flowdrop/flowdrop/styles');

					if (config.step) {
						// Tutorial mode: load step-specific config
						const { getTutorialConfig } = await import('../mocks/tutorial-data');
						const tutorial = getTutorialConfig(config.step);
						handlers = tutorial.handlers;
						mountOptions = {
							workflow: tutorial.workflow,
							nodes: tutorial.nodes,
							endpointConfig: createEndpointConfig('/api/flowdrop'),
							height: '100%',
							width: '100%',
							showNavbar: false,
							readOnly: config.readOnly,
							features: { autoSaveDraft: false },
							settings: {
								theme: 'dark',
								...(config.zoom && { editor: { defaultZoom: config.zoom } })
							}
						};
					} else {
						// Default demo mode
						const { handlers: defaultHandlers } = await import('../mocks/handlers');
						const { demoWorkflow, demoNodes } = await import('../mocks/data');
						handlers = defaultHandlers;
						mountOptions = {
							workflow: demoWorkflow,
							nodes: demoNodes,
							endpointConfig: createEndpointConfig('/api/flowdrop'),
							height: '100%',
							width: '100%',
							showNavbar: false,
							readOnly: config.readOnly,
							features: { autoSaveDraft: false },
							settings: {
								theme: 'dark',
								...(config.zoom && { editor: { defaultZoom: config.zoom } })
							}
						};
					}

					// Start MSW mock server
					const worker = setupWorker(...handlers);
					await worker.start({
						onUnhandledRequest: 'bypass',
						serviceWorker: { url: '/mockServiceWorker.js' },
						quiet: true
					});

					loadingEl.classList.add('hidden');
					editorEl.classList.remove('hidden');

					await mountFlowDropApp(editorEl, mountOptions);
				} catch (err) {
					console.error('FlowDrop demo failed:', err);
					loadingEl.classList.add('hidden');
					errorEl.classList.remove('hidden');
				}
			})();
		</script>
	</body>
</html>
