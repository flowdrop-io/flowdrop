---
/**
 * Standalone FlowDrop demo page.
 * Rendered in an iframe from the docs site for complete style isolation.
 * Query params (parsed client-side):
 *   ?readOnly=true   — read-only mode (no editing)
 *   ?showNavbar=true  — show the navbar
 *   ?step=1           — tutorial step (1-4)
 */
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<title>FlowDrop Demo</title>
		<style>
			*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
			html, body { width: 100%; height: 100%; overflow: hidden; }
			body { background: #1a1a2e; color: #e0e0e0; font-family: system-ui, sans-serif; }
			#editor { width: 100%; height: 100%; }
			#loading {
				display: flex;
				flex-direction: column;
				align-items: center;
				justify-content: center;
				height: 100%;
				gap: 1rem;
				color: #9ca3af;
			}
			.spinner {
				width: 2rem;
				height: 2rem;
				border: 3px solid #374151;
				border-top-color: #f97316;
				border-radius: 50%;
				animation: spin 0.8s linear infinite;
			}
			@keyframes spin { to { transform: rotate(360deg); } }
			.error {
				display: flex;
				flex-direction: column;
				align-items: center;
				justify-content: center;
				height: 100%;
				gap: 0.5rem;
				color: #9ca3af;
				text-align: center;
				padding: 2rem;
			}
			.error strong { color: #d1d5db; }
			.hidden { display: none !important; }
		</style>
	</head>
	<body>
		<div id="loading">
			<div class="spinner"></div>
			<p>Loading editor...</p>
		</div>
		<div id="error" class="error hidden">
			<p><strong>Could not load the demo.</strong></p>
			<p>Check the browser console for details.</p>
		</div>
		<div id="editor" class="hidden"></div>

		<script>
			(async () => {
				const params = new URLSearchParams(window.location.search);
				const config = {
					readOnly: params.get('readOnly') === 'true',
					showNavbar: params.get('showNavbar') === 'true',
					step: params.get('step') || '',
					zoom: params.get('zoom') ? parseFloat(params.get('zoom')) : null
				};
				const loadingEl = document.getElementById('loading');
				const errorEl = document.getElementById('error');
				const editorEl = document.getElementById('editor');

				try {
					// Determine handlers and mount options based on tutorial step
					let handlers;
					let mountOptions;

					const { setupWorker } = await import('msw/browser');
					const { mountFlowDropApp } = await import('@flowdrop/flowdrop/editor');
					const { createEndpointConfig } = await import('@flowdrop/flowdrop/core');
					await import('@flowdrop/flowdrop/styles');

					if (config.step) {
						// Tutorial mode: load step-specific config
						const { getTutorialConfig } = await import('../mocks/tutorial-data');
						const tutorial = getTutorialConfig(config.step);
						handlers = tutorial.handlers;
						mountOptions = {
							workflow: tutorial.workflow,
							nodes: tutorial.nodes,
							endpointConfig: createEndpointConfig('/api/flowdrop'),
							height: '100%',
							width: '100%',
							showNavbar: config.showNavbar,
							readOnly: config.readOnly,
							features: { autoSaveDraft: false },
							...(config.zoom && { settings: { editor: { defaultZoom: config.zoom } } })
						};
					} else {
						// Default demo mode
						const { handlers: defaultHandlers } = await import('../mocks/handlers');
						const { demoWorkflow, demoNodes } = await import('../mocks/data');
						handlers = defaultHandlers;
						mountOptions = {
							workflow: demoWorkflow,
							nodes: demoNodes,
							endpointConfig: createEndpointConfig('/api/flowdrop'),
							height: '100%',
							width: '100%',
							showNavbar: config.showNavbar,
							readOnly: config.readOnly,
							features: { autoSaveDraft: false },
							...(config.zoom && { settings: { editor: { defaultZoom: config.zoom } } })
						};
					}

					// Start MSW mock server
					const worker = setupWorker(...handlers);
					await worker.start({
						onUnhandledRequest: 'bypass',
						serviceWorker: { url: '/mockServiceWorker.js' },
						quiet: true
					});

					loadingEl.classList.add('hidden');
					editorEl.classList.remove('hidden');

					await mountFlowDropApp(editorEl, mountOptions);
				} catch (err) {
					console.error('FlowDrop demo failed:', err);
					loadingEl.classList.add('hidden');
					errorEl.classList.remove('hidden');
				}
			})();
		</script>
	</body>
</html>
