---
/**
 * Standalone FlowDrop playground demo page.
 * Rendered in an iframe from the docs site for complete style isolation.
 * Mounts the Playground component with MSW mock backend.
 */
---

<!doctype html>
<html lang="en" data-theme="dark">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<title>FlowDrop Playground Demo</title>
		<style>
			*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
			html, body { width: 100%; height: 100%; overflow: hidden; }
			body { background: #0a0a0f; color: #c0c0d8; font-family: system-ui, sans-serif; }
			#playground { width: 100%; height: 100%; }
			#loading {
				display: flex;
				flex-direction: column;
				align-items: center;
				justify-content: center;
				height: 100%;
				gap: 1rem;
				color: #7a7a9a;
			}
			.spinner {
				width: 2rem;
				height: 2rem;
				border: 3px solid #2a2a3a;
				border-top-color: #6c63ff;
				border-radius: 50%;
				animation: spin 0.8s linear infinite;
			}
			@keyframes spin { to { transform: rotate(360deg); } }
			.error {
				display: flex;
				flex-direction: column;
				align-items: center;
				justify-content: center;
				height: 100%;
				gap: 0.5rem;
				color: #7a7a9a;
				text-align: center;
				padding: 2rem;
			}
			.error strong { color: #c0c0d8; }
			.hidden { display: none !important; }

			/* Minimal (slate) skin tokens — applied in dark mode */
			:root {
				--fd-node-icon-display: none;
				--fd-node-circle-display: flex;
				--fd-sidebar-search-display: none;
				--fd-sidebar-header-display: none;
				--fd-sidebar-card-display: none;
				--fd-sidebar-flat-display: block;
				--fd-navbar-split-display: flex;
				--fd-navbar-dropdown-display: none;
			}
			[data-theme='dark'] {
				--fd-background: #13131a;
				--fd-foreground: #c0c0d8;
				--fd-muted: #1a1a28;
				--fd-muted-foreground: #7a7a9a;
				--fd-card: #1a1a28;
				--fd-card-foreground: #e8e8f0;
				--fd-border: #2a2a3a;
				--fd-border-muted: #1e1e2a;
				--fd-border-strong: #3a3a55;
				--fd-header: #1a1a25;
				--fd-layout-background: #0a0a0f;
				--fd-primary: #6c63ff;
				--fd-primary-hover: #7c74ff;
				--fd-primary-foreground: #ffffff;
				--fd-primary-muted: rgba(108, 99, 255, 0.15);
				--fd-scrollbar-thumb: #2a2a3a;
				--fd-scrollbar-track: #13131a;
				--fd-backdrop: rgba(19, 19, 26, 0.9);
				--fd-node-border: #9898b8;
				--fd-node-border-hover: #aeaed0;
				--fd-handle-border: #9898b8;
				--fd-sidebar-category-color: #3a3a55;
				--fd-sidebar-flat-item-color: #8888aa;
			}
		</style>
	</head>
	<body>
		<div id="loading">
			<div class="spinner"></div>
			<p>Loading playground...</p>
		</div>
		<div id="error" class="error hidden">
			<p><strong>Could not load the playground demo.</strong></p>
			<p>Check the browser console for details.</p>
		</div>
		<div id="playground" class="hidden"></div>

		<script>
			(async () => {
				const loadingEl = document.getElementById('loading');
				const errorEl = document.getElementById('error');
				const playgroundEl = document.getElementById('playground');

				try {
					const { setupWorker } = await import('msw/browser');
					const { handlers } = await import('../mocks/handlers');
					const { playgroundHandlers } = await import('../mocks/playground-handlers');
					const { mountPlayground } = await import('@flowdrop/flowdrop/playground');
					const { createEndpointConfig } = await import('@flowdrop/flowdrop/core');
					await import('@flowdrop/flowdrop/styles');

					// Start MSW with both editor and playground handlers
					const worker = setupWorker(...handlers, ...playgroundHandlers);
					await worker.start({
						onUnhandledRequest: 'bypass',
						serviceWorker: { url: '/mockServiceWorker.js' },
						quiet: true
					});

					loadingEl.classList.add('hidden');
					playgroundEl.classList.remove('hidden');

					await mountPlayground(playgroundEl, {
						workflowId: 'demo_tool_workflow',
						endpointConfig: createEndpointConfig('/api/flowdrop'),
						mode: 'standalone',
						config: {
							showTimestamps: true,
							autoScroll: true,
							pollingInterval: 800,
							enableMarkdown: true
						}
					});
				} catch (err) {
					console.error('FlowDrop playground demo failed:', err);
					loadingEl.classList.add('hidden');
					errorEl.classList.remove('hidden');
				}
			})();
		</script>
	</body>
</html>
