---
/**
 * Standalone FlowDrop playground demo page.
 * Rendered in an iframe from the docs site for complete style isolation.
 * Mounts the Playground component with MSW mock backend.
 */
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<title>FlowDrop Playground Demo</title>
		<style>
			*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
			html, body { width: 100%; height: 100%; overflow: hidden; }
			body { background: #1a1a2e; color: #e0e0e0; font-family: system-ui, sans-serif; }
			#playground { width: 100%; height: 100%; }
			#loading {
				display: flex;
				flex-direction: column;
				align-items: center;
				justify-content: center;
				height: 100%;
				gap: 1rem;
				color: #9ca3af;
			}
			.spinner {
				width: 2rem;
				height: 2rem;
				border: 3px solid #374151;
				border-top-color: #f97316;
				border-radius: 50%;
				animation: spin 0.8s linear infinite;
			}
			@keyframes spin { to { transform: rotate(360deg); } }
			.error {
				display: flex;
				flex-direction: column;
				align-items: center;
				justify-content: center;
				height: 100%;
				gap: 0.5rem;
				color: #9ca3af;
				text-align: center;
				padding: 2rem;
			}
			.error strong { color: #d1d5db; }
			.hidden { display: none !important; }
		</style>
	</head>
	<body>
		<div id="loading">
			<div class="spinner"></div>
			<p>Loading playground...</p>
		</div>
		<div id="error" class="error hidden">
			<p><strong>Could not load the playground demo.</strong></p>
			<p>Check the browser console for details.</p>
		</div>
		<div id="playground" class="hidden"></div>

		<script>
			(async () => {
				const loadingEl = document.getElementById('loading');
				const errorEl = document.getElementById('error');
				const playgroundEl = document.getElementById('playground');

				try {
					const { setupWorker } = await import('msw/browser');
					const { handlers } = await import('../mocks/handlers');
					const { playgroundHandlers } = await import('../mocks/playground-handlers');
					const { mountPlayground } = await import('@d34dman/flowdrop/playground');
					const { createEndpointConfig } = await import('@d34dman/flowdrop/core');
					await import('@d34dman/flowdrop/styles');

					// Start MSW with both editor and playground handlers
					const worker = setupWorker(...handlers, ...playgroundHandlers);
					await worker.start({
						onUnhandledRequest: 'bypass',
						serviceWorker: { url: '/mockServiceWorker.js' },
						quiet: true
					});

					loadingEl.classList.add('hidden');
					playgroundEl.classList.remove('hidden');

					await mountPlayground(playgroundEl, {
						workflowId: 'demo_tool_workflow',
						endpointConfig: createEndpointConfig('/api/flowdrop'),
						mode: 'standalone',
						config: {
							showTimestamps: true,
							autoScroll: true,
							pollingInterval: 800,
							enableMarkdown: true
						}
					});
				} catch (err) {
					console.error('FlowDrop playground demo failed:', err);
					loadingEl.classList.add('hidden');
					errorEl.classList.remove('hidden');
				}
			})();
		</script>
	</body>
</html>
