---
import type { Props } from '@astrojs/starlight/props';
import Search from '@astrojs/starlight/components/Search.astro';
import SiteTitle from './SiteTitle.astro';
---

<div class="header sl-flex">
	<div class="header-inner sl-flex">
		<div class="title-wrapper sl-flex">
			<SiteTitle {...Astro.props} />
		</div>
		<nav class="fd-header-nav sl-hidden md:sl-flex print:hidden" aria-label="Site navigation">
			<a href="/" class="fd-header-link">Docs</a>
			<a href="https://api.flowdrop.io/v1/" class="fd-header-link" target="_blank" rel="noopener noreferrer">API</a>
			<a href="https://flowdrop.io/blog" class="fd-header-link" target="_blank" rel="noopener noreferrer">Blog</a>
			<a href="https://github.com/flowdrop-io/flowdrop" class="fd-header-link" target="_blank" rel="noopener noreferrer">GitHub</a>
		</nav>
		<div class="search-wrapper sl-flex print:hidden">
			<Search {...Astro.props} />
		</div>
		<div class="sl-hidden md:sl-flex print:hidden right-group">
			<a href="https://docs.flowdrop.io/getting-started/quick-start" class="fd-header-cta">
				Get started
			</a>
		</div>
	</div>
</div>

<script>
	const header = document.querySelector('header.header');
	if (header) {
		const update = () => header.classList.toggle('fd-scrolled', window.scrollY > 32);
		window.addEventListener('scroll', update, { passive: true });
		update();
	}
</script>

<style>
	.header {
		height: 100%;
		width: 100%;
		justify-content: center;
	}

	.header-inner {
		width: 100%;
		max-width: 1200px;
		padding: 0 clamp(16px, 5vw, 48px);
		align-items: center;
		gap: 0.25rem;
		height: 100%;
	}

	.title-wrapper {
		overflow: clip;
		padding: 0.25rem;
		margin: -0.25rem;
		min-width: 0;
		flex-shrink: 0;
		margin-inline-end: 0.5rem;
	}

	.fd-header-nav {
		gap: 0.25rem;
		align-items: center;
		flex: 1;
	}

	.fd-header-link {
		font-size: 0.9375rem;
		font-weight: 500;
		color: var(--sl-color-gray-2);
		padding: 0.375rem 0.625rem;
		border-radius: 6px;
		text-decoration: none;
		transition: color 150ms ease, background-color 150ms ease;
	}

	.fd-header-link:hover {
		color: var(--sl-color-white);
		background-color: var(--sl-color-gray-5);
	}

	.search-wrapper {
		flex: 1;
		justify-content: flex-end;
		margin-inline-end: 0.75rem;
	}

	.right-group {
		align-items: center;
		flex-shrink: 0;
	}

	.fd-header-cta {
		font-size: 0.875rem;
		font-weight: 600;
		color: #fff;
		background-color: #6c63ff;
		padding: 0.4375rem 1rem;
		border-radius: 9999px;
		text-decoration: none;
		white-space: nowrap;
		box-shadow: 0 0 0 1px rgba(108, 99, 255, 0.3), 0 4px 20px rgba(108, 99, 255, 0.3);
		transition: background-color 150ms ease, box-shadow 150ms ease, transform 150ms ease;
	}

	.fd-header-cta:hover {
		background-color: #7c74ff;
		box-shadow: 0 0 0 1px rgba(108, 99, 255, 0.4), 0 8px 32px rgba(108, 99, 255, 0.4);
		transform: translateY(-1px);
	}
</style>
