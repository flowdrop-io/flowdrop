---
/**
 * Override of Starlight's Head component to add Mermaid initialization.
 * Renders the default head entries plus a client-side mermaid init script.
 */
const { head } = Astro.locals.starlightRoute;
---

{head.map(({ tag: Tag, attrs, content }) => <Tag {...attrs} set:html={content} />)}
{Astro.site && <meta property="og:image" content={new URL('/og-default.png', Astro.site).href} />}
{Astro.site && <meta name="twitter:image" content={new URL('/og-default.png', Astro.site).href} />}
<meta property="og:image:width" content="1200" />
<meta property="og:image:height" content="630" />
<meta property="og:type" content="website" />
<meta name="twitter:card" content="summary_large_image" />
<script>
	import mermaid from 'mermaid';

	/** Resolve a CSS custom property to a computed rgb/hex value. */
	function resolveColor(varName: string): string {
		const el = document.createElement('div');
		el.style.color = `var(${varName})`;
		el.style.display = 'none';
		document.body.appendChild(el);
		const resolved = getComputedStyle(el).color;
		el.remove();
		return resolved;
	}

	function getThemeVariables() {
		const isLight = document.documentElement.dataset.theme === 'light';

		const accent = resolveColor('--sl-color-accent');
		const accentLow = resolveColor('--sl-color-accent-low');
		const bg = resolveColor('--sl-color-black');
		const fg = resolveColor('--sl-color-white');
		const gray1 = resolveColor('--sl-color-gray-1');
		const gray2 = resolveColor('--sl-color-gray-2');
		const gray3 = resolveColor('--sl-color-gray-3');
		const gray4 = resolveColor('--sl-color-gray-4');
		const gray5 = resolveColor('--sl-color-gray-5');
		const gray6 = resolveColor('--sl-color-gray-6');

		return {
			// Background & text
			background: bg,
			primaryTextColor: fg,
			secondaryTextColor: gray1,
			tertiaryTextColor: gray3,
			lineColor: gray2,

			// Primary (accent — innermost nodes)
			primaryColor: accentLow,
			primaryBorderColor: accent,

			// Secondary (mid-level containers)
			secondaryColor: isLight ? gray6 : gray5,
			secondaryBorderColor: isLight ? gray4 : gray3,

			// Tertiary (outer containers)
			tertiaryColor: isLight ? gray5 : gray4,
			tertiaryBorderColor: isLight ? gray3 : gray2,

			// Nodes & labels
			noteBkgColor: accentLow,
			noteTextColor: fg,
			noteBorderColor: accent,

			// Flowchart
			nodeBorder: accent,
			mainBkg: accentLow,
			clusterBkg: isLight ? gray6 : gray5,
			clusterBorder: isLight ? gray4 : gray3,
			titleColor: fg,
			edgeLabelBackground: 'transparent',

			// Fonts
			fontFamily: "'Inter Variable', sans-serif",
			fontSize: '14px',
		};
	}

	function getMermaidConfig() {
		return {
			startOnLoad: false,
			theme: 'base' as const,
			themeVariables: getThemeVariables(),
			flowchart: {
				curve: 'basis',
				diagramPadding: 24,
			},
		};
	}

	// Store original diagram sources before first render
	const diagramSources = new Map<Element, string>();
	document.querySelectorAll('pre.mermaid').forEach((el) => {
		diagramSources.set(el, el.textContent ?? '');
	});

	mermaid.initialize(getMermaidConfig());
	await mermaid.run({ querySelector: 'pre.mermaid' });

	// Re-render diagrams when user toggles theme
	const observer = new MutationObserver(async () => {
		// Reset each diagram to its original source text so Mermaid re-processes it
		diagramSources.forEach((source, el) => {
			el.removeAttribute('data-processed');
			el.innerHTML = source;
		});
		mermaid.initialize(getMermaidConfig());
		await mermaid.run({ querySelector: 'pre.mermaid' });
	});

	observer.observe(document.documentElement, {
		attributes: true,
		attributeFilter: ['data-theme'],
	});
</script>
