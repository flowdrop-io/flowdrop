# =============================================================
# FlowDrop Docker Playground — Environment Configuration
# =============================================================
# Copy to .env and edit as needed:  cp .env.example .env

# --- Playground Access ---
# Port where the playground is accessible on your host machine.
PLAYGROUND_PORT=80

# --- FlowDrop UI ---
FLOWDROP_THEME=auto
FLOWDROP_TIMEOUT=30000
FLOWDROP_VERSION=playground

# --- LLM Provider (for Agent Spec runtime) ---
# Options: "ollama" or "openai"
LLM_PROVIDER=ollama

# --- Ollama ---
# Point to a host-machine Ollama instance:
OLLAMA_MODEL=llama3.2
OLLAMA_BASE_URL=http://host.docker.internal:11434

# --- OpenAI (used when LLM_PROVIDER=openai) ---
# OPENAI_API_KEY=sk-your-key-here
# OPENAI_MODEL=gpt-4o-mini
