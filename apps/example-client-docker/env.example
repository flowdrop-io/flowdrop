# FlowDrop Docker Example - Environment Variables
# Copy this file to .env and update the values for your environment

# ==============================================================================
# RUNTIME ENVIRONMENT VARIABLES
# ==============================================================================
# These variables are read by the server at runtime and served to the client
# via the /api/config endpoint. They can be changed without rebuilding.

# FlowDrop API Base URL
# The URL where your FlowDrop backend API is accessible
FLOWDROP_API_BASE_URL=http://localhost:8080/api/flowdrop

# Theme Configuration
# Options: light, dark, auto
FLOWDROP_THEME=auto

# Request Timeout
# Timeout for API requests in milliseconds
FLOWDROP_TIMEOUT=30000

# Authentication Configuration
# Options: none, bearer, api_key, custom
FLOWDROP_AUTH_TYPE=none

# Authentication Token
# Only used if FLOWDROP_AUTH_TYPE is set to bearer
FLOWDROP_AUTH_TOKEN=

# Agent Spec Runtime Base URL
# The URL where the Agent Spec runtime (pyagentspec/WayFlow) is accessible
# Leave empty to use the library default (http://localhost:8000)
# FLOWDROP_AGENTSPEC_BASE_URL=

# Application Version
# Version string displayed in the UI
FLOWDROP_VERSION=1.0.0

# ==============================================================================
# SERVER CONFIGURATION
# ==============================================================================

# Node Environment
NODE_ENV=production

# Port the server listens on
PORT=3000

# Host the server binds to
HOST=0.0.0.0
