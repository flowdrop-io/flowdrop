# FlowDrop UI Environment Variables
# Copy this file to .env and update the values for your environment

# ==============================================================================
# PRODUCTION ENVIRONMENT VARIABLES (Runtime - Server-Side)
# ==============================================================================
# These variables are read by the server at runtime and served to the client
# via the /api/config endpoint. They can be changed without rebuilding.

# FlowDrop API Base URL
# The URL where your FlowDrop backend API is accessible
FLOWDROP_API_BASE_URL=http://localhost:8080/api/flowdrop

# Alternative environment variable names (for compatibility)
# API_BASE_URL=http://localhost:8080/api/flowdrop

# Theme Configuration
# Options: light, dark, auto
FLOWDROP_THEME=auto

# Request Timeout
# Timeout for API requests in milliseconds
FLOWDROP_TIMEOUT=30000

# Authentication Configuration
# Options: none, bearer, api_key, custom
FLOWDROP_AUTH_TYPE=none

# Authentication Token
# Only used if FLOWDROP_AUTH_TYPE is set to bearer
FLOWDROP_AUTH_TOKEN=

# Application Version
# Version string displayed in the UI
FLOWDROP_VERSION=1.0.0

# Node Environment
# Options: development, production
NODE_ENV=production

# Server Configuration
# Port the server listens on
PORT=3000

# Host the server binds to
HOST=0.0.0.0

# ==============================================================================
# DEVELOPMENT ENVIRONMENT VARIABLES (Build-Time - Vite)
# ==============================================================================
# These variables are only used during development with `npm run dev`
# In production, use the server-side variables above

# Development API Base URL
VITE_API_BASE_URL=http://localhost:8080/api/flowdrop

# Alternative development variable names (for compatibility)
# VITE_DRUPAL_API_URL=http://localhost:8080/api/flowdrop
# VITE_FLOWDROP_API_URL=http://localhost:8080/api/flowdrop

# Development Theme
VITE_FLOWDROP_THEME=auto

# Development Timeout
VITE_FLOWDROP_TIMEOUT=30000

# Development Auth Type
VITE_FLOWDROP_AUTH_TYPE=none

# Development Auth Token
VITE_FLOWDROP_AUTH_TOKEN=

# ==============================================================================
# MOCK API (MSW - Mock Service Worker)
# ==============================================================================
# Enable MSW mock server for development without a backend
# When enabled, all API requests are intercepted and served by the browser

# Enable/Disable Mock API
# Set to "true" to use MSW mock server (no backend required)
VITE_MOCK_API=false

# When using mock API, set the base URL to relative path:
# VITE_API_BASE_URL=/api/flowdrop

# ==============================================================================
# DOCKER COMPOSE VARIABLES
# ==============================================================================
# These variables are used by docker-compose.yml

# External port mapping
# PORT=3000

